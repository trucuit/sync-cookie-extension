PORT=8787
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_app_client_secret
# Optional: comma-separated exact origins. If empty, server allows chrome-extension://<id> by default.
GITHUB_OAUTH_ALLOWED_ORIGINS=
# Optional: comma-separated redirect URI prefixes (e.g. https://abcdefghijklmnopabcdefghijklmnop.chromiumapp.org/)
GITHUB_OAUTH_ALLOWED_REDIRECT_URI_PREFIXES=
