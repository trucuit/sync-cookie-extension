PORT=8787

# GitHub OAuth exchange
GITHUB_OAUTH_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_OAUTH_CLIENT_SECRET=your_github_oauth_app_client_secret

# Firebase proxy (auth + sync)
FIREBASE_API_KEY=your_firebase_web_api_key
FIREBASE_DB_URL=https://your-project-default-rtdb.asia-southeast1.firebasedatabase.app

# Optional hardening: comma-separated exact origins.
# If empty, server allows chrome-extension://<id> and localhost origins by default.
PROXY_ALLOWED_ORIGINS=

# Optional: comma-separated redirect URI prefixes
# Example: https://abcdefghijklmnopabcdefghijklmnop.chromiumapp.org/
GITHUB_OAUTH_ALLOWED_REDIRECT_URI_PREFIXES=

# Optional rate limiting per IP
PROXY_RATE_LIMIT_MAX=120
PROXY_RATE_LIMIT_WINDOW_MS=60000
