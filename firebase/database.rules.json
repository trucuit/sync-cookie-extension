{
  "rules": {
    ".read": false,
    ".write": false,
    "sync": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.hasChildren(['payload', 'updatedAt']) && newData.child('payload').isString() && newData.child('updatedAt').isString()"
      }
    }
  }
}
